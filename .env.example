# ---------------------------------------------------------------------------
# Let's Tech Club — "48 Hours to Survive in the AI Era"
# Operations Platform — environment template.
# Copy to `.env` and populate with real secrets. NEVER commit the populated file.
# ---------------------------------------------------------------------------

# Runtime profile: development | testing | production
APP_ENV=development

# --- Core security ---------------------------------------------------------
SECRET_KEY=replace-with-a-long-random-string

# --- Authentication --------------------------------------------------------
# Root admin account (email-OTP login, admin role) — seeded automatically.
ROOT_ADMIN_EMAIL=kyawkokotunmm475157@gmail.com
# Public base URL used to build invitation links in emails.
APP_BASE_URL=http://localhost:8000
# Default email transport. SMTP is optional and disabled by default.
USE_SMTP=false
# Resend API key for outbound mail.
RESEND_KEY=replace-with-your-resend-api-key
# OTP behaviour
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
# Community program limits
PARTICIPANT_SELECTION_CAP=80
MAX_TEAM_SIZE=12
# In non-production, echo the OTP in the API response/logs when no SMTP exists.
OTP_DEV_ECHO=true
# Seed demo data on first container boot.
SEED_ON_BOOT=true

# --- Database --------------------------------------------------------------
# For docker-compose this points at the postgres service hostname `db`.
DATABASE_URL=postgresql+psycopg2://hackops:hackops@db:5432/hackops

# --- Vercel deployment -----------------------------------------------------
# On Vercel, attach the "Postgres" (Neon) storage integration to the project.
# Vercel then injects POSTGRES_URL / POSTGRES_URL_NON_POOLING automatically and
# the app picks them up — you do NOT need to set DATABASE_URL yourself.
# If you bring your own Postgres instead, set DATABASE_URL explicitly and
# include sslmode=require, for example:
#   DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# VERCEL, VERCEL_URL and VERCEL_PROJECT_PRODUCTION_URL are set by Vercel itself;
# the app uses them to build correct OTP/invitation links with no extra config.
# Required env vars to set in the Vercel dashboard: APP_ENV=production,
# SECRET_KEY, ROOT_ADMIN_EMAIL, and RESEND_KEY.

# --- Resend (default) ------------------------------------------------------
MAIL_DEFAULT_SENDER=Hackathon <no-reply@thespot.solutions>

# --- SMTP / Flask-Mail (secondary fallback; set USE_SMTP=true to enable) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=ops@letstechclub.org
MAIL_PASSWORD=your-app-specific-password

# --- Gunicorn (production container) ---------------------------------------
GUNICORN_WORKERS=3
GUNICORN_BIND=0.0.0.0:8000
